---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const projects = allWork.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Work" description="Civic technology projects and tools.">
  <div class="max-w-2xl mx-auto px-6 py-16">

    <h1 class="font-display text-4xl font-semibold tracking-tight mb-2">Work</h1>
    <div class="w-10 h-0.5 bg-forest mb-3"></div>
    <p class="text-stone-500 text-sm mb-12">
      Tools, dashboards, and civic technology projects.
    </p>

    {projects.length === 0 ? (
      <p class="text-stone-400 text-sm">Projects coming soon.</p>
    ) : (
      <div class="divide-y divide-stone-100">
        {projects.map((project) => (
          <article class="py-7 group">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h2 class="font-display text-xl font-medium text-ink group-hover:text-forest transition-colors leading-snug mb-2">
                  {project.data.url ? (
                    <a href={project.data.url} target="_blank" rel="noopener">
                      {project.data.title} ↗
                    </a>
                  ) : (
                    <a href={`/work/${project.slug}`}>{project.data.title}</a>
                  )}
                </h2>
                <p class="text-sm text-stone-500 leading-relaxed mb-3">
                  {project.data.description}
                </p>
                <div class="flex items-center gap-3 flex-wrap">
                  {project.data.tags.length > 0 && project.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                  {project.data.github && (
                    <a href={project.data.github} target="_blank" rel="noopener"
                       class="text-xs text-stone-400 hover:text-stone-700 transition-colors">
                      GitHub →
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

  </div>
</BaseLayout>
